{
  "name": "bowling-bracket-desktop-core",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "ui:dev": "vite",
    "ui:build": "vite build",
    "dev:desktop": "concurrently -k \"bun run dev\" \"bun run ui:dev\"",
    "start": "bun src/server.ts",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "build:desktop-resources": "bun run scripts/build-desktop.ts"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "vite": "^8.0.0"
  },
  "dependencies": {
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
